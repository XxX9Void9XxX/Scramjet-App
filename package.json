    "@mercuryworkshop/wisp-js": "^0.4.1",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.4.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.11.5",
    "ws": "^8.18.3"
